NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000

# PostgreSQL / Supabase
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Sessions
SESSION_SECRET=replace_with_a_long_random_secret
SESSION_COOKIE_SECURE=false

# Email
RESEND_API_KEY=re_your_resend_api_key

# Slack contact-form alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Optional admin bootstrap used by database/scripts/init_db.js
DEFAULT_ADMIN_NAME=ElectroHub Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace_with_a_strong_admin_password
